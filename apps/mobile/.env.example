# Copy to .env and set your machine's LAN IP (same Wi‑Fi as the phone).
# Server terminal prints candidates when you run: npm run dev:server
EXPO_PUBLIC_API_BASE_URL=http://192.168.1.XXX:4000

# Android emulator → host machine:
# EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:4000

# After editing .env, restart Metro with a clean cache:
#   npm run dev:mobile:clear   (from repo root)
