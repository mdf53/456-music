EXPO_PUBLIC_SPOTIFY_CLIENT_ID=your_spotify_client_id_here
# API URL must match the SAME network as Expo/Metro (the exp:// IP in the Expo logs).
# Example: if Metro shows exp://192.168.86.26:8081, use http://192.168.86.26:4000 — NOT a VPN
# or virtual adapter IP (10.x from Hyper-V/WSL/VPN often won't work from your phone).
# localhost is OK for web emulator on the same PC only.
EXPO_PUBLIC_API_BASE_URL=http://localhost:4000
